diff --git a/src/pcm-iok.cpp b/src/pcm-iok.cpp
new file mode 100644
index 0000000..e8f9d70
--- /dev/null
+++ b/src/pcm-iok.cpp
@@ -0,0 +1,54 @@
+#include "cpucounters.h"
+
+using namespace pcm;
+
+extern "C" {
+
+       bool init = false;
+       PCM *p_pcm;
+       ServerUncorePMUs *p_unc;
+
+       uint64_t pcm_iok_get_cas_count(uint32 channel)
+       {
+               uint64_t reads = p_unc->getMCCounter(
+                       channel, ServerUncorePMUs::EventPosition::READ);
+               uint64_t writes = p_unc->getMCCounter(
+                       channel, ServerUncorePMUs::EventPosition::WRITE);
+               return reads + writes;
+       }
+
+
+       uint64_t pcm_iok_get_max_channel_count(void)
+       {
+               return p_unc->getNumMCChannels();
+       }
+
+       uint64_t pcm_iok_get_active_channel_count(void)
+       {
+               uint64_t count = 0;
+               for (uint64_t i = 0; i < p_unc->getNumMCChannels(); i++)
+                       count += pcm_iok_get_cas_count(i) != 0;
+               return count;
+       }
+
+       int pcm_iok_init(int socket)
+       {
+               if (init) {
+                       return 0;
+               }
+
+               p_pcm = PCM::getInstance();
+               p_unc = new pcm::ServerUncorePMUs(socket, p_pcm);
+               p_unc->program();
+               init = true;
+               return 0;
+       }
+
+       void pcm_iok_deinit(void)
+       {
+               if (!init) {
+                       return;
+               }
+               p_pcm->cleanup();
+       }
+}
